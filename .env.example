# ==========================================================================
# Day Spa & Wellness Booking System — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any file containing real secrets.
# ==========================================================================

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
# Public base URL of the app (used for redirects, webhooks, emails).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime environment: development | production | test
NODE_ENV=development

# --------------------------------------------------------------------------
# Supabase (public — safe to expose to the browser)
# --------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --------------------------------------------------------------------------
# Supabase (server-only — NEVER expose to the client)
# The service role key bypasses Row Level Security. Server-side use only.
# --------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --------------------------------------------------------------------------
# Edge Function secrets (set with `supabase secrets set`, NOT in .env.local)
# --------------------------------------------------------------------------
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into the Edge Functions runtime. APP_URL and the payment
# provider secrets below must be set explicitly for the functions.
APP_URL=http://localhost:3000

# --------------------------------------------------------------------------
# Payments — PayFast (server-only, also required by the Edge Functions)
# --------------------------------------------------------------------------
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# --------------------------------------------------------------------------
# Payments — Ozow (server-only)
# --------------------------------------------------------------------------
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_API_KEY=
OZOW_IS_TEST=true

# --------------------------------------------------------------------------
# Notifications (server-only) — configured in later milestones
# --------------------------------------------------------------------------
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=
